# Allowed CORS origins (comma-separated). Override for staging/production.
# BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-staging-domain.example.com

# Database connection (used when running locally outside Docker)
DATABASE_URL=postgresql://yapat_user:yapat_password@localhost:5432/yapat

# Path on the host machine containing raw datasets.
# This will be mounted into the container at /data (read-only).
HOST_DATA_ROOT=/absolute/path/to/your/datasets

# Path used *inside the container* to access mounted datasets.
# Do not change unless modifying docker-compose.
DATA_ROOT=/data

# Celery configuration (local development)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# PAM Active Learning device. Keep cpu for local development; set cuda on GPU deployments.
PAM_DEFAULT_DEVICE=cpu

# Active Learning / WSSED species models (optional)
# Host path for species model weights - mounted into the container.
# Use an absolute path or relative path (e.g. ./models_AL). Must exist on the host.
# HOST_MODELS_AL=./models_AL

# Base directory for species-specific model weights (.pt files) inside the container.
# Expected layout: <ACTIVE_LEARNING_MODELS_DIR>/<species_safe_name>/best_<metric>_model_<level>.pt
# Example: models_AL/my_bird/best_macro_model_segment.pt
# ACTIVE_LEARNING_MODELS_DIR=models_AL